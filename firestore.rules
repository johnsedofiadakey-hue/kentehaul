rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@kentehaul.com';
    }

    // --- PUBLIC CONTENT (READ ONLY) ---
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if true; // Customers can post reviews
      allow delete: if isAdmin();
    }

    // --- SENSITIVE DATA (PROTECTED) ---
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.query.limit == 0); 
      allow get: if true; // Allow tracking by specific ID
      allow create: if true; // Allow checkout
      allow update, delete: if isAdmin();
    }
    
    match /customers/{phone} {
      allow read: if isAdmin(); // Protect CRM data
      allow create, update: if true; // Public can register/update their own profile during checkout
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity']) || isAdmin();
      allow create, delete: if isAdmin();
    }
    
    match /wishlists/{clientId} {
      allow read: if isAdmin();
      allow write: if true; 
    }
    
    match /activity_log/{logId} {
      allow read: if isAdmin();
      allow create: if true; 
    }
    
    match /mail/{mailId} {
      allow read: if false; 
      allow create: if true; 
      allow update, delete: if false;
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
