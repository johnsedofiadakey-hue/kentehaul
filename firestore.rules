rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@kentehaul.com';
    }

    // --- PUBLIC CONTENT (READ ONLY) ---
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if true; // Customers can post reviews
      allow delete: if isAdmin();
    }

    // --- SENSITIVE DATA (PROTECTED) ---
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.query.limit == 0); // Allow tracking via search by ID if implemented
      allow get: if true; // Allow tracking by specific ID
      allow create: if true; // Allow checkout
      allow update, delete: if isAdmin();
    }
    
    match /customers/{phone} {
      allow read, update: if isAdmin();
      allow create: if true; // Allow checkout to register customer
    }
    
    match /wishlists/{clientId} {
      allow read: if isAdmin();
      allow write: if true; // Public can sync their own wishlist
    }
    
    match /activity_log/{logId} {
      allow read: if isAdmin();
      allow create: if true; // Public can log events
    }
    
    match /mail/{mailId} {
      allow read: if false; // Security: No one reads sent mail triggers
      allow create: if true; // Anyone can trigger an order receipt
      allow update, delete: if false;
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
