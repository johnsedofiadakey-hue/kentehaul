rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- AUTH HELPERS ---
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@kentehaul.com';
    }

    // --- PUBLIC READ, ADMIN WRITE ---
    
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /products/{product} {
      allow read: if true;
      allow write: if isAdmin();
      // Ensure stockQuantity is always non-negative during admin updates
      allow update: if isAdmin() && request.resource.data.stockQuantity >= 0;
    }
    
    match /gallery/{image} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feedbacks/{feedback} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- REVIEWS (PUBLIC CREATE, PUBLIC READ, ADMIN MANAGE) ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.rating >= 1 
                   && request.resource.data.rating <= 5
                   && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // --- SENSITIVE DATA (ADMIN ONLY / SECURE) ---

    match /customers/{customer} {
      allow read, write: if isAdmin();
    }

    match /orders/{order} {
      allow list: if isAdmin();
      allow get: if true; 
      allow create: if request.resource.data.status == 'Order Placed' || request.resource.data.status == 'Payment Confirmed';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Email Extension Collection
    match /mail/{mailId} {
        allow create: if true;
        allow read, update, delete: if isAdmin();
    }
  }
}
