rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- AUTH HELPERS ---
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@kentehaul.com';
    }

    // --- PUBLIC READ, ADMIN WRITE ---
    
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{image} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feedbacks/{feedback} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- REVIEWS (PUBLIC CREATE, PUBLIC READ, ADMIN MANAGE) ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.rating >= 1 
                   && request.resource.data.rating <= 5
                   && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }
    
    // --- SENSITIVE DATA (ADMIN ONLY / SECURE) ---
    match /customers/{customer} {
      allow read: if true; // Required for merge-sets during checkout
      allow create, update: if true;
    }

    match /orders/{order} {
      allow list: if isAdmin();
      allow get: if true; 
      allow create: if request.resource.data.status in ['Order Placed', 'Payment Confirmed'];
      allow update: if isAdmin();
    }
    
    match /products/{product} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow public to decrement stock
      allow update: if request.resource.data.stockQuantity < resource.data.stockQuantity
                    || isAdmin();
    }
    
    // --- PARTNERSHIPS ---
    match /partnerships/{partnership} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
