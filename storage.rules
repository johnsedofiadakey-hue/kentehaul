rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Products and site images are public
      allow read: if true;
      
      // Only Admin can upload/delete
      // Note: In firestore.rules we check for auth != null. 
      // We should be consistent.
      allow write: if request.auth != null && request.auth.token.email == 'admin@kentehaul.com';
    }
  }
}
